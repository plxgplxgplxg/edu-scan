generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(uuid()) @db.Uuid
  email             String             @unique
  passwordHash      String
  name              String
  role              Role
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  studentCode       String?            @unique
  assignments       Assignment[]       @relation("TeacherAssignments")
  assignmentSubmits AssignmentSubmit[]
  taughtClasses     Class[]            @relation("TeacherClasses")
  classEnrollments  ClassEnrollment[]
  exams             Exam[]             @relation("TeacherExams")
  notifications     Notification[]     @relation("RecipientNotifications")
  omrBatches        OmrBatch[]         @relation("TeacherOmrBatches")
  submissions       Submission[]       @relation("StudentSubmissions")
}

model Class {
  id              String            @id @default(uuid()) @db.Uuid
  name            String
  subject         String
  schoolYear      String
  code            String            @unique
  teacherId       String            @db.Uuid
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  assignments     Assignment[]
  teacher         User              @relation("TeacherClasses", fields: [teacherId], references: [id])
  enrollments     ClassEnrollment[]
  examAssignments ExamClass[]

  @@index([teacherId])
}

model ClassEnrollment {
  id        String   @id @default(uuid()) @db.Uuid
  classId   String   @db.Uuid
  studentId String   @db.Uuid
  joinedAt  DateTime @default(now())
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@index([studentId])
}

model Exam {
  id            String        @id @default(uuid()) @db.Uuid
  title         String
  maxScore      Float
  teacherId     String        @db.Uuid
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  status        ExamStatus    @default(DRAFT)
  questionCount Int           @default(0)
  teacher       User          @relation("TeacherExams", fields: [teacherId], references: [id])
  classes       ExamClass[]
  variants      ExamVariant[]
  omrBatches    OmrBatch[]
  submissions   Submission[]

  @@index([teacherId])
}

model ExamVariant {
  id          String       @id @default(uuid()) @db.Uuid
  examId      String       @db.Uuid
  testCode    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  answerKeys  AnswerKey[]
  exam        Exam         @relation(fields: [examId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@unique([examId, testCode])
  @@index([examId])
}

model ExamClass {
  id      String @id @default(uuid()) @db.Uuid
  examId  String @db.Uuid
  classId String @db.Uuid
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
  exam    Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([examId, classId])
}

model AnswerKey {
  id             String       @id @default(uuid()) @db.Uuid
  questionNumber Int
  variantId      String       @db.Uuid
  correctAnswer  AnswerChoice
  variant        ExamVariant  @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, questionNumber])
}

model OmrBatch {
  id             String         @id @default(uuid()) @db.Uuid
  examId         String         @db.Uuid
  teacherId      String         @db.Uuid
  status         OmrBatchStatus @default(PENDING)
  totalFiles     Int
  processedFiles Int            @default(0)
  successCount   Int            @default(0)
  failedCount    Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  completedAt    DateTime?
  exam           Exam           @relation(fields: [examId], references: [id], onDelete: Cascade)
  teacher        User           @relation("TeacherOmrBatches", fields: [teacherId], references: [id])
  submissions    Submission[]

  @@index([teacherId])
  @@index([examId])
}

model Submission {
  id                       String                   @id @default(uuid()) @db.Uuid
  examId                   String                   @db.Uuid
  studentId                String?                  @db.Uuid
  batchId                  String?                  @db.Uuid
  studentCode              String?
  status                   SubmissionStatus         @default(NEEDS_REVIEW)
  imageUrl                 String?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  processedImageUrl        String?
  annotatedImageUrl        String?
  warpOverlayUrl           String?
  answerScoresUrl          String?
  resolvedVariantId        String?                  @db.Uuid
  detectedTestId           String?
  resolvedTestCode         String?
  testCodeResolutionStatus TestCodeResolutionStatus
  studentCodeRaw           String?
  matchedStudentId         String?                  @db.Uuid
  isExternal               Boolean                  @default(false)
  reviewedAt               DateTime?
  score                    Float?
  maxScore                 Float?
  correctCount             Int?
  wrongCount               Int?
  reviewCount              Int?
  gradedAt                 DateTime?
  batch                    OmrBatch?                @relation(fields: [batchId], references: [id])
  exam                     Exam                     @relation(fields: [examId], references: [id], onDelete: Cascade)
  resolvedVariant          ExamVariant?             @relation(fields: [resolvedVariantId], references: [id])
  student                  User?                    @relation("StudentSubmissions", fields: [studentId], references: [id])
  details                  SubmissionDetail[]

  @@index([examId, score])
  @@index([examId, studentId])
  @@index([batchId, status])
  @@index([batchId])
  @@index([batchId, createdAt])
  @@index([batchId, status, createdAt])
  @@index([studentCode])
  @@index([resolvedVariantId])
  @@index([testCodeResolutionStatus])
}

model SubmissionDetail {
  id             String        @id @default(uuid()) @db.Uuid
  submissionId   String        @db.Uuid
  questionNumber Int
  needsReview    Boolean       @default(false)
  reviewReason   String?
  detectedAnswer String?
  finalAnswer    AnswerChoice?
  correctAnswer  AnswerChoice?
  isCorrect      Boolean?
  submission     Submission    @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@unique([submissionId, questionNumber])
  @@index([submissionId])
}

model Assignment {
  id                              String             @id @default(uuid()) @db.Uuid
  title                           String
  description                     String?
  instructionFileUrl              String?
  instructionFilePublicId         String?
  instructionFileOriginalName     String?
  instructionFileMimeType         String?
  instructionFileSizeBytes        Int?
  instructionFileUploadedAt       DateTime?
  deadline                        DateTime
  allowLate                       Boolean            @default(false)
  latePenaltyPct                  Float              @default(0)
  maxScore                        Float              @default(10)
  teacherId                       String             @db.Uuid
  createdAt                       DateTime           @default(now())
  updatedAt                       DateTime           @updatedAt
  classId                         String             @db.Uuid
  class                           Class              @relation(fields: [classId], references: [id])
  teacher                         User               @relation("TeacherAssignments", fields: [teacherId], references: [id])
  submits                         AssignmentSubmit[]

  @@index([teacherId])
  @@index([classId])
}

model AssignmentSubmit {
  id                   String       @id @default(uuid()) @db.Uuid
  assignmentId         String       @db.Uuid
  studentId            String       @db.Uuid
  note                 String?
  fileUrl              String?
  filePublicId         String?
  fileOriginalName     String?
  fileMimeType         String?
  fileSizeBytes        Int?
  fileUploadedAt       DateTime?
  submitStatus         SubmitStatus
  gradeStatus          GradeStatus  @default(PENDING)
  score                Float?
  feedback             String?
  submittedAt          DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  assignment           Assignment   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student              User         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([studentId])
}

model Notification {
  id           String    @id @default(uuid()) @db.Uuid
  type         String
  recipientId  String    @db.Uuid
  roleTarget   Role
  entityId     String?   @db.Uuid
  classId      String?   @db.Uuid
  assignmentId String?   @db.Uuid
  batchId      String?   @db.Uuid
  routeIntent  Json
  title        String
  body         String
  dedupeKey    String    @unique
  readAt       DateTime?
  createdAt    DateTime  @default(now())
  recipient    User      @relation("RecipientNotifications", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, readAt, createdAt])
  @@index([type, createdAt])
  @@index([classId])
  @@index([assignmentId])
  @@index([batchId])
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum AnswerChoice {
  A
  B
  C
  D
}

enum SubmissionStatus {
  GRADED
  NEEDS_REVIEW
  FAILED
}

enum TestCodeResolutionStatus {
  MATCHED
  UNKNOWN_TEST_CODE
  MISSING_TEST_CODE
  AMBIGUOUS_TEST_CODE
}

enum OmrBatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  PARTIAL_FAILED
  FAILED
}

enum SubmitStatus {
  ON_TIME
  LATE
}

enum GradeStatus {
  PENDING
  GRADED
}

enum ExamStatus {
  DRAFT
  PUBLISHED
}
